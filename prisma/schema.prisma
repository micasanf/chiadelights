generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  email           String?
  phone           String
  address         String?
  deliveryMethod  String   // "delivery" or "pickup"
  flavor          String   // selected flavor
  size            String   // "regular" or "large"
  quantity        Int      @default(1)
  paymentMethod   String   // "gcash", "maya", "bank_transfer", "cod"
  paymentProof    String?  // base64 data URL of screenshot
  specialRequests String?
  totalAmount     Float
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
